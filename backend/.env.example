# ==== Darna backend environment template ====
# Copy to backend/.env and fill in real values. Never commit the real .env.
NODE_ENV=development
PORT=5050
CLIENT_URL=http://localhost:5173

# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://user:pass@cluster0.example.mongodb.net/darna?retryWrites=true&w=majority

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-random-32-byte-hex
JWT_REFRESH_SECRET=replace-with-random-32-byte-hex
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# OpenAI — for the AI concierge
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# NFC verified-visit HMAC secret — generate with: openssl rand -hex 32
NFC_PROOF_SECRET=replace-with-random-32-byte-hex
